# Local development (outside Docker)
# Infrastructure runs in Docker with exposed ports

# Database
DATABASE_URL=postgresql+asyncpg://cod:cod@localhost:5432/cod_agent

# MinIO
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=cod-documents

# LLM
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=qwen2.5:7b
LLM_TIMEOUT=600

# Embeddings (faster multilingual model for local CPU dev; bge-m3 for prod)
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DEVICE=cpu
EMBEDDING_VECTOR_SIZE=384

# Qdrant
QDRANT_URL=http://localhost:6333

# Auth
JWT_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Modules
PARSER_BACKEND=pdfplumber
PII_FILTER=noop
QUEUE_BACKEND=background_tasks
